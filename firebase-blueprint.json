{
  "entities": {
    "Post": {
      "title": "Blog Post",
      "description": "A blog post in the portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["title", "content", "tags", "userId", "createdAt"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message submitted through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": { "$ref": "Post" },
      "description": "Stores all blog posts."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "ContactMessage" },
      "description": "Stores contact form submissions."
    }
  }
}
