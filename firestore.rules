rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives & Helpers ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == 'official.edwinsafo@gmail.com';
    }

    // --- Entity Validators ---
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'tags', 'userId', 'createdAt', 'status']) &&
             data.keys().size() == 6 &&
             data.title is string && data.title.size() <= 100 && data.title.size() > 0 &&
             data.content is string && data.content.size() <= 20000 &&
             data.tags is list && data.tags.size() <= 10 &&
             (data.tags.size() == 0 || data.tags[0] is string) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.status is string && data.status.matches('^(published|draft)$');
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() <= 100 && data.name.size() > 0 &&
             data.email is string && data.email.size() <= 100 && data.email.size() > 0 &&
             data.message is string && data.message.size() <= 2000 && data.message.size() > 0 &&
             data.createdAt is timestamp;
    }

    // --- Collections ---

    // Posts Collection
    match /posts/{postId} {
      // Public can read published posts. Admin can read all.
      // We must explicitly use resource.data check for list.
      allow get, list: if isAdmin() || resource.data.status == 'published';

      allow create: if isAdmin() && 
                       isValidId(postId) && 
                       isValidPost(incoming()) && 
                       incoming().createdAt == request.time;

      allow update: if isAdmin() &&
                       isValidId(postId) &&
                       isValidPost(incoming()) &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().userId == existing().userId &&
                       (
                         // Action: Edit post
                         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'tags', 'status'])
                       );

      allow delete: if isAdmin() && isValidId(postId);
    }

    // Messages Collection
    match /messages/{messageId} {
      allow get, list: if isAdmin();

      // Anyone can leave a message without signing in, but must pass strict validation
      allow create: if isValidId(messageId) && 
                       isValidMessage(incoming()) && 
                       incoming().createdAt == request.time;
      
      // Messages shouldn't be updated by users
      allow update: if false;

      allow delete: if isAdmin() && isValidId(messageId);
    }
  }
}
